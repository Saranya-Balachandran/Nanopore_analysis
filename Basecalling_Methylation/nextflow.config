// global configurations
nextflow.enable.dsl=2

// Set a default location to circumvent warning of no initialized value
params {
    outfolder = '$SCRATCH'
}

// profile dependendent configurations
profiles {
    omics {
        conda {
            enabled = true
        }
        singularity {
            enabled = true
            cacheDir = "$WORK/singularity/"
        }
        executor {
            $slurm {
                queue = "shortterm"
            }
        }
        // use singularity for everything
        /* conda {
            enabled = true
        } */
        queue = "shortterm"
        workDir = "$WORK/nanopore_workdir"
        process {
            executor = 'slurm'
            scratch =  '$SCRATCH/' // has to be single quotes. Otherwise it gets expanded before creating a new slurm job
            withLabel: gpu {
                cpus = 32
		memory = 47.GB
                beforeScript = 'module load nvidia-cuda'
                clusterOptions = {"--gres=gpu:1"}
                containerOptions = { workflow.containerEngine == "singularity" ? '--nv':
       ( workflow.containerEngine == "docker" ? '--gpus all': null ) }
                container = "saranyabalachandr/dorado_1.4.0:v1"
		}

            withLabel: 'cpu'{
	memory = 500.GB
	cpus = 4
	beforeScript = 'module load samtools'
	}
                }
        }
}
